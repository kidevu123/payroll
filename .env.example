# ─────────────────────────────────────────────────────────────────────────────
# Payroll — environment template
# Copy to .env (never commit). Secrets live here; everything else lives in
# the Setting table and is editable from /admin/settings.
# ─────────────────────────────────────────────────────────────────────────────

# Required: Postgres connection string used by the app and drizzle-kit.
# In docker compose this points at the postgres service.
DATABASE_URL="postgresql://payroll:payroll@localhost:5432/payroll"

# Required: 32+ random bytes, base64 encoded. Used by Auth.js to sign sessions.
# Generate with:  openssl rand -base64 48
AUTH_SECRET=""

# Required: 32 random bytes, base64. Used by AES-GCM to encrypt secrets stored
# in the Setting table (NGTeco credentials, etc).
# Generate with:  openssl rand -base64 32
NGTECO_VAULT_KEY=""

# Public URL the app is served from (used for absolute links in notifications,
# magic-link emails, payslip download links, etc.). No trailing slash.
APP_URL="http://localhost:3000"

# Trust X-Forwarded-* headers? Set to true when behind a reverse proxy.
TRUST_PROXY="false"

# OpenTelemetry — defaults to console exporter when this is empty.
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_SERVICE_NAME="payroll"

# First-run owner bootstrap (optional). When the database has zero users on
# first boot, the app will refuse to start unless you either:
#   (a) Set OWNER_EMAIL + OWNER_PASSWORD here and let the seed create them, or
#   (b) Visit /setup in a browser and create the OWNER interactively.
# Leaving these blank picks (b).
OWNER_EMAIL=""
OWNER_PASSWORD=""

# Storage root inside the container. The host mounts /data here in compose.
STORAGE_ROOT="/data"

# Node env. Set to "production" in compose; "development" locally.
NODE_ENV="development"
